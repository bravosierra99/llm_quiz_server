# Copy to .env and adjust. docker-compose reads this automatically.

# --- AI question generation (OpenAI-compatible endpoint) ---
# Any OpenAI-compatible server works (LM Studio, Ollama, vLLM, llama.cpp,
# OpenAI itself, etc.). The /v1 suffix matters. Default points at a local
# LM Studio instance on this machine.
AI_BASE_URL=http://localhost:1234/v1
# Model id as served by the endpoint. "local-model" works if only one is loaded.
AI_MODEL=local-model
# API token for the endpoint, if it requires one. Leave blank if auth is off.
AI_API_KEY=
# Seconds to wait on a generation call. Local models can run 1-2 min/batch.
AI_TIMEOUT=180

# --- auth / admin ---
# Used to sign the profile cookie. Set to a long random string in production:
#   openssl rand -hex 32
QUIZ_SECRET_KEY=change-me-to-a-long-random-string
# Comma-separated emails that become admins when they sign in (matched against
# the Cloudflare Access email header, if you put Access in front of the app).
ADMIN_EMAILS=you@example.com
